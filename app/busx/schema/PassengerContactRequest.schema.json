{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://busx.example/schemas/PassengerContactRequest.schema.json",
  "title": "PassengerContactRequest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "fare_ref_id": {
      "type": "string",
      "minLength": 6,
      "description": "Maps to departure.fare_ref_id"
    },
    "reservations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": { "$ref": "#/$defs/ReservationPassenger" }
    },
    "contact": { "$ref": "#/$defs/Contact" },
    "locale": { "type": "string", "default": "en_US" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3, "default": "THB" },
    "time_zone": { "type": "string", "default": "Asia/Bangkok" }
  },
  "required": ["fare_ref_id", "reservations", "contact"],
  "$defs": {
    "ReservationPassenger": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "seat_event_id": {
          "type": "string",
          "description": "Returned from mark_seats. If not present, your backend may still accept seat_number-based flows depending on provider behavior."
        },
        "seat_number": {
          "type": "string",
          "pattern": "^[A-Z]?\\d{1,3}[A-Z]?$"
        },
        "passenger_type_code": {
          "type": "string",
          "enum": ["ADT", "CHD", "INF", "SRC"],
          "default": "ADT"
        },
        "passenger_title_id": {
          "type": "integer",
          "enum": [1, 2, 3, 4, 5, 6, 7],
          "description": "1=Mr,2=Ms,3=Mrs,4=Boy,5=Girl,6=Monk,7=Nuns"
        },
        "passenger_name": {
          "type": "string",
          "minLength": 1,
          "description": "Full name as a single string (your current implementation)."
        },
        "passenger_birth_date": {
          "type": "string",
          "format": "date",
          "description": "Optional YYYY-MM-DD"
        },
        "passenger_gender": {
          "type": "string",
          "enum": ["M", "F", "U"],
          "default": "U"
        },
        "passenger_phone_country": {
          "type": "string",
          "minLength": 2,
          "maxLength": 3,
          "default": "TH",
          "description": "Country code like TH"
        },
        "passenger_phone_number": {
          "type": "string",
          "minLength": 3,
          "maxLength": 30
        },
        "passenger_email": {
          "type": "string",
          "format": "email"
        },
        "passenger_card_type": {
          "type": "string",
          "enum": [
            "U",
            "ID_CARD",
            "PASSPORT",
            "VISA",
            "DRIVER_LICENSE",
            "BORDER_CROSSING_CARD",
            "ALIEN_REGISTRATION_CARD",
            "GOVERNMENT_ID",
            "MILITARY_ID"
          ],
          "default": "U"
        },
        "passenger_card_no": { "type": "string" }
      },
      "required": ["passenger_type_code", "passenger_name", "passenger_gender", "passenger_phone_country", "passenger_phone_number"]
    },
    "Contact": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contact_title_id": {
          "type": "integer",
          "enum": [1, 2, 3, 4, 5, 6, 7]
        },
        "contact_title": {
          "type": "string",
          "enum": ["Mr.", "Ms.", "Mrs.", "Boy", "Girl", "Monk", "Nuns"]
        },
        "contact_name": { "type": "string", "minLength": 1 },
        "contact_email": { "type": "string", "format": "email" },
        "contact_phone_country": { "type": "string", "minLength": 2, "maxLength": 3, "default": "TH" },
        "contact_phone_number": { "type": "string", "minLength": 3, "maxLength": 30 }
      },
      "required": ["contact_name", "contact_phone_country", "contact_phone_number"]
    }
  }
}
