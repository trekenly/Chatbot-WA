{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://busx.example/schemas/NormalizedIntent.schema.json",
  "title": "NormalizedIntent",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "default": "1.0" },

    "original_text": { "type": "string" },

    "detected_language": {
      "type": "string",
      "description": "ISO 639-1 if possible (th, en, zh, my, km, lo, etc.)"
    },
    "locale": { "type": "string", "description": "e.g. th_TH, en_US, zh_CN" },
    "time_zone": { "type": "string", "default": "Asia/Bangkok" },
    "currency": { "type": "string", "minLength": 3, "maxLength": 3, "default": "THB" },

    "intent": {
      "type": "string",
      "enum": [
        "TripSearch",
        "TripChoice",
        "SeatPick",
        "PassengerContact",
        "MarkSeats",
        "CreateReservation",
        "CreatePayment",
        "Status",
        "Details",
        "Reset",
        "Help",
        "Unknown"
      ]
    },

    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },

    "payload": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "trip_search": { "$ref": "https://busx.example/schemas/TripSearchRequest.schema.json" },
        "trip_choice": { "$ref": "https://busx.example/schemas/TripChoiceRequest.schema.json" },
        "seat_pick": { "$ref": "https://busx.example/schemas/SeatPickRequest.schema.json" },
        "passenger_contact": { "$ref": "https://busx.example/schemas/PassengerContactRequest.schema.json" }
      }
    },

    "missing_fields": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of missing fields your system should ask the user for."
    },

    "clarifying_question": {
      "type": "string",
      "description": "If missing_fields is non-empty, the LLM can suggest what to ask next."
    }
  },
  "required": ["intent", "confidence"],
  "allOf": [
    {
      "if": { "properties": { "intent": { "const": "TripSearch" } }, "required": ["intent"] },
      "then": {
        "required": ["payload"],
        "properties": { "payload": { "required": ["trip_search"] } }
      }
    },
    {
      "if": { "properties": { "intent": { "const": "TripChoice" } }, "required": ["intent"] },
      "then": {
        "required": ["payload"],
        "properties": { "payload": { "required": ["trip_choice"] } }
      }
    },
    {
      "if": { "properties": { "intent": { "const": "SeatPick" } }, "required": ["intent"] },
      "then": {
        "required": ["payload"],
        "properties": { "payload": { "required": ["seat_pick"] } }
      }
    },
    {
      "if": { "properties": { "intent": { "const": "PassengerContact" } }, "required": ["intent"] },
      "then": {
        "required": ["payload"],
        "properties": { "payload": { "required": ["passenger_contact"] } }
      }
    }
  ]
}
