{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://busx.example/schemas/SeatPickRequest.schema.json",
  "title": "SeatPickRequest",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "fare_ref_id": {
      "type": "string",
      "minLength": 6,
      "description": "Used for seat layout + mark_seats."
    },
    "seat_floor": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3,
      "default": 1
    },
    "seat_numbers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "items": {
        "type": "string",
        "pattern": "^[A-Z]?\\d{1,3}[A-Z]?$",
        "description": "Examples: 12, 12A, A3, B10"
      },
      "description": "Selected seats (count must match pax total you enforce in your orchestrator)."
    }
  },
  "required": ["seat_numbers"]
}
